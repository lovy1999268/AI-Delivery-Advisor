# Database Configuration
# For local development with Windows Authentication, leave DB_USER and DB_PASSWORD empty
# For cloud or SQL authentication, fill in all values

# SQL Server Address/Hostname
DB_SERVER=localhost
# or for cloud: DB_SERVER=your-server.database.windows.net

# Database Name
DB_NAME=AI_Delivery_Advisor

# SQL Server Authentication (leave empty for Windows auth)
DB_USER=
DB_PASSWORD=

# OpenAI API Key
OPENAI_API_KEY=your-api-key-here
