# ===================================================
# DATABASE CONFIGURATION - LOCAL DEVELOPMENT
# ===================================================

# For SQL Server Standard/Enterprise (local default instance):
DB_SERVER=localhost

# For SQL Server Express (local):
# DB_SERVER=localhost\SQLEXPRESS

# For remote/Azure SQL Server:
# DB_SERVER=your-server.database.windows.net

# Database Name
DB_NAME=AI_Delivery_Advisor

# SQL Server Authentication (optional)
# Leave empty to use Windows Authentication (recommended for local dev)
# Fill in for SQL Server Authentication or cloud deployments
DB_USER=
DB_PASSWORD=

# OpenAI API Key (if using OpenAI)
# OPENAI_API_KEY=sk-

# ===================================================
# TROUBLESHOOTING
# ===================================================
# 
# Error: "Server is not found or not accessible"
# 1. Check if SQL Server is running:
#    - Windows: Services > SQL Server (MSSQLSERVER or SQLEXPRESS)
# 2. Try these server names:
#    - localhost\SQLEXPRESS (SQL Server Express)
#    - localhost (SQL Server Standard/Enterprise)
#    - (local) (Alternative syntax)
#    - 127.0.0.1 (IP address)
# 3. Verify database exists: AI_Delivery_Advisor
#
# Error: "Login failed for user"
# 1. Check credentials are correct
# 2. If using Windows auth, leave DB_USER and DB_PASSWORD empty
# 3. If using SQL auth, make sure user account exists
#
# Error: "Connection timeout"
# 1. Check if server is accessible (firewall rules)
# 2. Check SQL Server is configured for remote connections
# 3. Try TCP/IP protocol in SQL Server Configuration Manager
